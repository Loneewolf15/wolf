# ===========================================
# Environment Configuration Template
# ===========================================
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control!
# ===========================================

# Application Environment
APP_ENV=development
APP_DEBUG=true
APP_NAME=DivineAPI

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=market_plaza_pid2025

# Paystack Configuration
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Monnify Configuration
MONNIFY_API_KEY=MK_TEST_your_api_key_here
MONNIFY_SECRET_KEY=your_secret_key_here
MONNIFY_CONTRACT_CODE=your_contract_code_here
MONNIFY_ENV=sandbox

# Default Payment Provider
DEFAULT_PAYMENT_PROVIDER=paystack

# Email Configuration
MAIL_FROM_NAME=DivineAPI
MAIL_FROM_ADDRESS=noreply@divineapi.com
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_USERNAME=your_email@domain.com
SMTP_PASSWORD=your_email_password
SMTP_ENCRYPTION=ssl

# JWT Secret (Generate a long random string)
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Application URL
APP_URL=http://localhost/backendTemplate

# Session & Security
SESSION_LIFETIME=120
SECURE_COOKIES=false
