$db = db_connect("localhost", "root", "secret", "mockdb")
$stmt = db_prepare($db, "SELECT * FROM users WHERE status = :status")
db_bind($stmt, ":status", "active")
db_execute($stmt)
$users = db_fetch_all($stmt)
$one = db_fetch_one($stmt)
print($users)
print($one)
print(db_row_count($stmt))
print(db_last_insert_id($db))
db_close($db)
