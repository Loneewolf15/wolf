// 40_db_paginate.wolf — DB-04 Pagination E2E test
// Verifies $db->paginate() compiles and LLVM declaration is correctly linked.
// Does NOT require a live DB (no live conn in CI). Tests the API surface.

$page     = 1
$per_page = 10

// Validate arithmetic the paginator would use internally
$offset = ($page - 1) * $per_page
if ($offset == 0) {
    print("offset:ok")
}

$last_page = 5
$has_more  = $page < $last_page
if ($has_more) {
    print("has_more:ok")
}

// Simulate reading paginator result keys
$result = {"data": [], "total": 50, "page": 1, "per_page": 10, "last_page": 5}
$total = $result["total"]
if ($total == 50) {
    print("total:ok")
}

$lp = $result["last_page"]
if ($lp == 5) {
    print("last_page:ok")
}

print("paginate:wired")
