// BUG-001: HTTP Engine Data Race on http_contexts
// Trigger: Concurrently writing to HTTP response under load
// Expected: No segfault, clean memory access
// Actual: SEGV on unknown address due to cross-thread memory corruption

func handler($req: int, $res: int) {
    wolf_http_res_status($res, 200)
    wolf_http_res_write($res, "Hello World from Wolf")
}

wolf_http_serve(8084, handler)
