# Test: howl and function are valid aliases for func
# All three keyword styles must produce identical output

# Original style
func add($a, $b) {
    return $a + $b
}

# Wolf-branded style
howl multiply($a, $b) {
    return $a * $b
}

# PHP/JS-familiar style
function greet($name) {
    return "Hello " .. $name
}

# Test all three
$sum     = add(3, 4)
$product = multiply(3, 4)
$msg     = greet("Wolf")

print($sum)
print($product)
print($msg)

# Test howl and function inside a class
class Calculator {
    howl square($n) {
        return $n * $n
    }

    function cube($n) {
        return $n * $n * $n
    }
}

$calc = new Calculator
print($calc->square(5))
print($calc->cube(3))
