# Test: howl and function are valid aliases for func
# All three keyword styles must produce identical output

# Original style - automatically uses dynamic math fallback
func add($a, $b) {
    return $a + $b
}

# Wolf-branded style - without types
howl multiply($a, $b) {
    return $a * $b
}

# PHP/JS-familiar style
function greet($name: string) -> string {
    return "Hello " .. $name
}

$sum     = add(3, 4)
$product = multiply(3, 4)
$msg     = greet("Wolf")

print($sum)
print($product)
print($msg)

