# wolf.config — Wolf language runtime configuration
# equivalent to php.ini: place this in your project root.
# Environment variables always override file values (12-factor pattern).
# Run `wolf build` or `wolf run` and these values are baked into the binary.
#
# Sections: [app]  [server]  [database]  [redis]  [jwt]  [log]  [build]

# ── Application ──────────────────────────────────────────────────────
[app]
name    = wolf-app
env     = development          # development | staging | production
debug   = false
version = 1.0.0
key     =                      # APP_KEY: set to a long random string in production

# ── HTTP Server ──────────────────────────────────────────────────────
[server]
host            = 0.0.0.0
port            = 2006
read_timeout    = 30           # seconds
write_timeout   = 30           # seconds
max_request_size = 65536       # bytes (64 KB)
max_concurrent  = 1024         # max simultaneous open connections
workers         = 0            # 0 = auto-detect CPU count

# ── Database (MySQL) ─────────────────────────────────────────────────
# Credentials are baked into the binary as compile-time constants via -D flags.
# They are NEVER written to the binary's data segment as readable strings;
# set DB_PASSWORD via environment variable in production.
[database]
host         = localhost
port         = 3306
name         =                 # DB_NAME — set your database name here
user         =                 # DB_USER
password     =                 # DB_PASSWORD — prefer env var in production

# Connection pool — tuned for throughput, never open a new connection per request
pool_size    = 10              # total connections kept open
pool_min_idle = 2              # connections warmed up at startup
pool_timeout  = 30             # seconds to wait for a free slot under load
max_retries   = 3              # reconnect attempts on stale connection

# read_host =                  # DB_READ_HOST: optional read replica
# read_port = 3306

# ── Redis ─────────────────────────────────────────────────────────────
[redis]
host     = 127.0.0.1
port     = 6379
password =
db       = 0

# ── JWT ──────────────────────────────────────────────────────────────
[jwt]
secret         =               # JWT_SECRET — required if using RouteProtection
expiry_minutes = 60
algorithm      = HS256         # HS256 | HS384 | HS512

# ── Logging ──────────────────────────────────────────────────────────
[log]
level  = info                  # debug | info | warning | error
output = stdout                # stdout | file
# file = /var/log/wolf-app.log

# ── Build ─────────────────────────────────────────────────────────────
[build]
out_dir    = wolf_out
optimise   = true              # -O2 in production, -O0 for debugging
keep_ll    = false             # keep generated .ll LLVM IR file
strict_mode = false
